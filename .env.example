# --- Azure OpenAI (GPT, multimodal) ---
# In practice these are sourced from ../CooperBench/azure_env.sh -> ../code-world-models/.env
# The openai SDK's AzureOpenAI client reads AZURE_API_BASE / AZURE_API_KEY / AZURE_API_VERSION.
AZURE_API_BASE=
AZURE_API_KEY=
AZURE_API_VERSION=

# --- Anthropic (Claude) ---
# NOT required for Phase 0 (Claude predictions are produced by the Claude Code agent reading images).
# Required for the full re-runnable harness of the article.
ANTHROPIC_API_KEY=

# --- Hugging Face (optional, only for gated/faster downloads) ---
HF_TOKEN=
